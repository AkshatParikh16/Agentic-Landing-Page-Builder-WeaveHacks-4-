# OpenAI — required for all agents
OPENAI_API_KEY=sk-...

# Weights & Biases / Weave — optional but recommended for tracing
WANDB_API_KEY=
WEAVE_PROJECT=landing-page-builder

# Quality gate — Judge must score >= this to pass (default 8)
EVAL_PASS_SCORE=8

# Max improvement loops after initial build (default 2)
MAX_IMPROVE_ITERATIONS=2
